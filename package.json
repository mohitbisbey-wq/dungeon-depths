{
  "name": "dungeon-depths",
  "version": "1.0.0",
  "description": "Pixel art roguelite dungeon crawler",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "serve": "python3 -m http.server 8091 --directory public",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "vitest run && playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^1.6.1",
    "vitest": "^1.6.0"
  }
}
